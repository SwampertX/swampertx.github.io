{
  "version": "3.0.0",
  "name": "gatsby-starter-lumen",
  "description": "A minimal, lightweight and mobile-first starter for creating blazing-fast static blogs",
  "main": "n/a",
  "scripts": {
    "start": "npm run clean && gatsby develop",
    "build": "npm run clean && gatsby build",
    "deploy": "gatsby build && gh-pages -d public -b master",
    "clean": "rimraf .cache public",
    "lint:js": "eslint --fix --cache --ext .js,.jsx --ignore-pattern public .",
    "lint:scss": "stylelint \"src/**/*.scss\"",
    "lint": "concurrently \"npm run lint:js\" \"npm run lint:scss\" && npm run prettier",
    "prettier": "prettier --write 'src/**/*.{js,jsx,ts,tsx}' ",
    "test": "jest --config ./tests/jest-config.js",
    "test:coverage": "jest --coverage --config ./tests/jest-config.js",
    "test:watch": "jest --watch --config ./tests/jest-config.js"
  },
  "repository": "https://github.com/SwampertX/swampertx.github.io",
  "author": "Tan Yee Jian <tanyeejian@gmail.com>",
  "license": "MIT",
  "keywords": [
    "gatsby",
    "graphql",
    "netlify",
    "netlify-cms",
    "pagination",
    "categories",
    "tags",
    "prismjs",
    "static",
    "lost",
    "blog",
    "minimal",
    "react",
    "theme",
    "starter",
    "disqus"
  ],
  "dependencies": {
    "acorn": "^7.1.0",
    "bluebird": "^3.7.0",
    "classnames": "^2.2.6",
    "codecov": "^3.6.1",
    "core-js": "^3.2.1",
    "dotenv": "^8.1.0",
    "gatsby": "^2.15.29",
    "gatsby-link": "^2.2.18",
    "gatsby-plugin-catch-links": "^2.1.12",
    "gatsby-plugin-feed": "^2.3.15",
    "gatsby-plugin-google-analytics": "^2.1.20",
    "gatsby-plugin-manifest": "^2.2.20",
    "gatsby-plugin-netlify": "^2.1.17",
    "gatsby-plugin-netlify-cms": "^4.1.22",
    "gatsby-plugin-offline": "^3.0.11",
    "gatsby-plugin-react-helmet": "^3.1.10",
    "gatsby-plugin-sass": "^2.1.17",
    "gatsby-plugin-sharp": "^2.2.28",
    "gatsby-plugin-sitemap": "^2.2.16",
    "gatsby-remark-copy-linked-files": "^2.1.24",
    "gatsby-remark-images": "^3.1.25",
    "gatsby-remark-prismjs": "^3.3.17",
    "gatsby-remark-relative-images": "^0.2.3",
    "gatsby-remark-responsive-iframe": "^2.2.21",
    "gatsby-remark-smartypants": "^2.1.11",
    "gatsby-source-filesystem": "^2.1.28",
    "gatsby-transformer-remark": "^2.6.27",
    "gatsby-transformer-sharp": "^2.2.20",
    "immutable": "^3.8.2",
    "invariant": "^2.2.4",
    "lodash": "^4.17.15",
    "moment": "^2.23.0",
    "netlify-cms": "^2.9.7",
    "node-sass": "^4.11.0",
    "normalize-scss": "^7.0.1",
    "npm": "^6.11.3",
    "prismjs": "^1.17.1",
    "react": "^16.10.2",
    "react-disqus-comments": "^1.4.0",
    "react-dom": "^16.10.2",
    "react-helmet": "^5.2.0",
    "redux": "^3.7.2",
    "slate": "^0.33.8",
    "typescript": "^3.6.3",
    "webpack": "^4.41.0"
  },
  "devDependencies": {
    "@babel/core": "^7.6.2",
    "@babel/plugin-proposal-class-properties": "^7.5.5",
    "@babel/plugin-proposal-optional-chaining": "^7.6.0",
    "@babel/preset-env": "^7.6.2",
    "@babel/preset-react": "^7.0.0",
    "autoprefixer": "^9.6.4",
    "babel-core": "^7.0.0-0",
    "babel-eslint": "^10.0.3",
    "babel-jest": "^24.9.0",
    "browserslist": "^4.7.0",
    "concurrently": "^4.1.2",
    "eslint": "^5.12.1",
    "eslint-config-airbnb-base": "^14.0.0",
    "eslint-config-prettier": "^6.4.0",
    "eslint-plugin-import": "^2.18.2",
    "eslint-plugin-jest": "^22.17.0",
    "eslint-plugin-prettier": "^3.1.1",
    "eslint-plugin-react": "^7.16.0",
    "eslint-watch": "^6.0.1",
    "gh-pages": "^2.1.1",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^24.9.0",
    "jest-cli": "^24.9.0",
    "lost": "^8.3.0",
    "postcss-pxtorem": "^4.0.1",
    "prettier": "^1.18.2",
    "react-test-renderer": "^16.10.2",
    "rimraf": "^3.0.0",
    "stylelint": "^11.0.0",
    "stylelint-config-recommended-scss": "^4.0.0",
    "stylelint-scss": "^3.11.1"
  }
}
